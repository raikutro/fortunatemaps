<!doctype html>
<html lang="en">

<head>
	<%- include('head') %>

		<link rel="stylesheet" type="text/css" href="/css/home.css">

		<title>Fortunate Maps - Home</title>
</head>

<body>
	<%- include('nav'); %>

		<main role="main" class="container">
			<% if (announcementHTML) { %>
				<hr>
				<p class="text-center" style="font-size: 1.25rem;">
					<%- announcementHTML %>
				</p>
				<hr>
				<% } else { %>
					<span></span>
					<% } %>
						<div class="row mb-3">
							<div class="col-12">
								<ul class="nav nav-tabs justify-content-center">
									<li class="nav-item">
										<a class="nav-link <%= sortMode === 'week' ? 'active' : '' %>"
											href="/?sort=week">Most
											Upvoted (Week)</a>
									</li>
									<li class="nav-item">
										<a class="nav-link <%= sortMode === 'new' ? 'active' : '' %>"
											href="/?sort=new">Newest</a>
									</li>
								</ul>
							</div>
						</div>
						<div class="map-container">
							<%- include('maplister'); %>
						</div>

						<%- include('pagination'); %>
		</main>

		<footer class="py-3 bg-primary text-light">
			<div class="container">
				<p class="text-center m-0">Developed by Electro ⚡</p>
			</div>
		</footer>

		<%- include('bodyscripts') %>
</body>

</html>