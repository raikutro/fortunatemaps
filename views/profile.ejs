<!doctype html>
<html lang="en">
	<head>
		<%- include('head') %>

		<link rel="stylesheet" type="text/css" href="/css/profile.css">

		<title>Fortunate Maps - Profile</title>
	</head>
	<body>
		<%- include('nav'); %>
		<div class="banner">
			<% if (bannerMap) { %>
				<img class="profile-banner-img" alt="Profile Banner" data-quality="hq" data-compressed-layout="<%- bannerMap.png %>" data-compressed-logic="<%- bannerMap.json %>" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" />
			<% } %>
		</div>
		<main role="main" class="container">
			<div class="banner-overlay">
				<h2 class="profile-username"><%- user.username %></h2>
			</div>

			<div class="row" id="mainRow">
				<div class="col-md-6">
					<div class="card">
						<div class="card-body">
							<div class="bio-text" id="bioText" markdown="<%= user.bio || `*${SETTINGS.FILLERS.BIO[Math.floor(Math.random() * SETTINGS.FILLERS.BIO.length)]}*`%>">
							</div>
							<hr>
							<div class="social-container">
								<div class="social-expander" <%- user.tagproProfile ? "" : "style='display:none'" %>>
									<img class="social-icon" src="https://tagpro.koalabeast.com/favicon.ico">
									<p class="social-handle">
										<a href="https://tagpro.koalabeast.com/profile/<%- user.tagproProfile %>" target="_blank"><%- user.tagproProfile %></a>
									</p>
								</div>
								<div class="social-expander" <%- user.social.discord ? "" : "style='display:none'" %>>
									<img class="social-icon" src="/assets/discord.png">
									<p class="social-handle"><%- user.social.discord %></p>
								</div>
								<div class="social-expander" <%- user.social.reddit ? "" : "style='display:none'" %>>
									<img class="social-icon" src="https://www.reddit.com/favicon.ico">
									<p class="social-handle">
										<a href="https://reddit.com/u/<%- user.social.reddit %>" target="_blank">/u/<%- user.social.reddit %></a>
									</p>
								</div>
							</div>
						</div>
					</div>
					<hr>
					<div class="card">
						<div class="card-header">
							Favorite Maps
						</div>
					</div>
					<hr>
				</div>
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							Certifications
						</div>
						<div class="card-body d-flex flex-row flex-wrap align-items-center justify-content-center">
							<% if (user.certifications.length > 0) { %>
								<% user.certifications.forEach(certification => { %>
									<% let certData = SETTINGS.SITE.CERTIFICATIONS[certification.certificationType]; %>
									<span class="certification badge badge-primary mb-2 mr-2" style="background: <%= certData.backgroundColor %>; color: <%= certData.textColor %>"><%= certification.name || certData.name %></span>
								<% }); %>
							<% } else { %>
								Unfortunately, this person isn't known for anything.
							<% } %>
						</div>
					</div>
					<hr>
					<% const isMtc = profile && profile.certifications && profile.certifications.some(c => c.certificationType === 2); %>
					<% if (isMtc && profile._id.toString() !== user._id.toString()) { %>
						<div class="input-group mb-3">
							<select class="custom-select" id="profileActionSelect">
								<option value="manage_certs">Manage MTC Certification</option>
							</select>
							<div class="input-group-append">
								<button class="btn btn-primary" type="button" id="runProfileActionBtn">Run</button>
							</div>
						</div>
					<% } %>
				</div>
			</div>
			<hr>
			<div class="profile-map-container">
				<%- include('maplister'); %>
				<div class="mt-4 d-flex justify-content-center">
					<%- include('pagination'); %>
				</div>
			</div>
		</main>

		<%- include('bodyscripts') %>

		<div class="modal fade" id="manageCertsModal" tabindex="-1" role="dialog" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered" role="document">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Manage MTC Certification</h5>
						<button type="button" class="close" data-dismiss="modal" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
					<div class="modal-body text-center mt-3 mb-3">
						<p class="mb-4">You can manually grant or revoke the MTC certification for <strong><%= user.username %></strong> below.</p>
						<button class="btn btn-success m-2" onclick="manageMtcAction('add', '<%= user._id %>')"><i class="fas fa-plus"></i> Award MTC</button>
						<button class="btn btn-danger m-2" onclick="manageMtcAction('revoke', '<%= user._id %>')"><i class="fas fa-minus"></i> Revoke MTC</button>
					</div>
				</div>
			</div>
		</div>
		
		<script type="text/javascript" src="/js/profile.js"></script>
	</body>
</html>