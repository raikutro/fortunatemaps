<nav class="map-pagination-container" aria-label="Page navigation example">
	<ul class="pagination">
		<!-- Previous -->
		<li class="page-item <%= page === 1 ? 'disabled' : '' %>">
			<a class="page-link" href="<%= (typeof paginationPrefix !== 'undefined'
            ? paginationPrefix
            : '/search?q=' + encodeURIComponent(query || '') + '&p=') + (page - 1) %>" aria-label="Previous">
				<span aria-hidden="true">&laquo;</span>
			</a>
		</li>

		<!-- Page Numbers -->
		<% const range=Math.min(9, maxPage); const lowestPageIndex=Math.min( Math.max(1, page - Math.floor(range / 2)),
			Math.max(1, maxPage - range + 1) ); %>

			<% for (let idx=0; idx < range; idx++) { const currentPage=lowestPageIndex + idx; %>
				<li class="page-item <%= page === currentPage ? 'active' : '' %>">
					<a class="page-link" href="<%= (typeof paginationPrefix !== 'undefined'
              ? paginationPrefix
              : '/search?q=' + encodeURIComponent(query || '') + '&p=') + currentPage %>">
						<%= currentPage %>
					</a>
				</li>
				<% } %>

					<!-- Next -->
					<li class="page-item <%= page === maxPage ? 'disabled' : '' %>">
						<a class="page-link" href="<%= (typeof paginationPrefix !== 'undefined'
            ? paginationPrefix
            : '/search?q=' + encodeURIComponent(query || '') + '&p=') + (page + 1) %>" aria-label="Next">
							<span aria-hidden="true">&raquo;</span>
						</a>
					</li>
	</ul>
</nav>